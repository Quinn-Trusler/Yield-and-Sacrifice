[sub_resource type="Shader" id="Shader_ta6n1"]
code = "shader_type canvas_item;
render_mode unshaded;

// Sprite texture
uniform sampler2D TEXTURE : source_color;

// --- Color controls ---
uniform float brightness = 1.02;
uniform float contrast   = 1.08;
uniform float saturation = 1.10;
uniform float gamma      = 1.05;

// --- CRT geometry ---
uniform float curvature = 0.14;
uniform float vignette  = 0.38;

// --- Scanlines ---
uniform float scanline_strength = 0.95;
uniform float scanline_density  = 1.15;

// --- VHS artifacts ---
uniform float chroma_offset = 0.002;
uniform float jitter = 0.002;
uniform float wobble = 0.003;

float hash(float n){
    return fract(sin(n)*43758.5453123);
}

vec2 crt_curve(vec2 uv, float k){
    vec2 cc = uv*2.0 - 1.0;
    vec2 d = cc*cc;
    cc *= 1.0 + k * vec2(d.y, d.x);
    return cc*0.5 + 0.5;
}

vec3 apply_color(vec3 c){
    c *= brightness;
    c = mix(vec3(0.5), c, contrast);

    float l = dot(c, vec3(0.2126,0.7152,0.0722));
    c = mix(vec3(l), c, saturation);

    c = pow(c, vec3(1.0/max(gamma,0.0001)));
    return c;
}

void fragment(){

    vec2 uv = UV;
    float t = TIME;

    // line jitter
    float line = floor(uv.y*600.0);
    uv.x += (hash(line + floor(t*20.0))*2.0-1.0) * jitter;

    // slow wobble
    uv.x += sin(uv.y*8.0 + t*1.2)*wobble;

    // CRT curve
    uv = crt_curve(uv, curvature);

    // chromatic aberration
    float r = texture(TEXTURE, uv + vec2(chroma_offset,0)).r;
    float g = texture(TEXTURE, uv).g;
    float b = texture(TEXTURE, uv - vec2(chroma_offset,0)).b;

    vec3 col = vec3(r,g,b);

    // scanlines
    float scan = sin(uv.y*800.0*scanline_density);
    col *= 1.0 - scanline_strength*(0.5-0.5*scan);

    // vignette
    vec2 v = uv - 0.5;
    float vig = smoothstep(0.9,0.2,dot(v,v)*2.0);
    col *= mix(1.0-vignette,1.0,vig);

    col = apply_color(col);

    COLOR = vec4(col, texture(TEXTURE, UV).a);
}"

